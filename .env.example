# ── Hedera Operator (pays all transaction fees) ──────────────────────────────
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=302e...
HEDERA_NETWORK=testnet

# ── HCS Topic IDs (created by `npm run setup`) ───────────────────────────────
# Run `npm run setup` once, then paste the output below
HCS_BOUNTY_TOPIC_ID=0.0.XXXXX
HCS_BID_TOPIC_ID=0.0.XXXXX
HCS_RESULT_TOPIC_ID=0.0.XXXXX
HCS_VERDICT_TOPIC_ID=0.0.XXXXX

# ── HTS Token (created by `npm run setup`) ───────────────────────────────────
HTS_TOKEN_ID=0.0.XXXXX

# ── Agent Accounts (optional — defaults to HEDERA_ACCOUNT_ID for single-account demo) ──
# WORKER_ACCOUNT_ID=0.0.XXXXX
# WORKER_PRIVATE_KEY=302e...
# REQUESTER_ACCOUNT_ID=0.0.XXXXX
# REQUESTER_PRIVATE_KEY=302e...
# JUDGE_ACCOUNT_ID=0.0.XXXXX
# JUDGE_PRIVATE_KEY=302e...

# ── Worker 1 Account (optional — defaults to HEDERA_ACCOUNT_ID) ─────────────
# WORKER_ACCOUNT_ID=0.0.XXXXX
# WORKER_PRIVATE_KEY=302e...

# ── Worker 2 Account (distinct identity for the second Worker agent) ──────────
# WORKER2_ACCOUNT_ID=0.0.XXXXX
# WORKER2_PRIVATE_KEY=302e...

# ── Worker LLM (Gemini 2.5 Flash + Hedera Agent Kit) ─────────────────────────
# Worker 1 API key — si absent : fallback x402 mock
# GEMINI_API_KEY=AIzaSy...

# Worker 2 API key — si absent : fallback x402 mock
# WORKER2_GEMINI_API_KEY=AIzaSy...

# ── LLM Judge ─────────────────────────────────────────────────────────────────
# Options: hardcoded (default, no API key) | claude
LLM_PROVIDER=hardcoded
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── x402 Mock Server ──────────────────────────────────────────────────────────
X402_SERVER_PORT=4020
X402_SERVER_URL=http://localhost:4020

# Requester Agent
REQUESTER_ACCOUNT_ID=0.0.XXXXX
REQUESTER_PRIVATE_KEY=302e...

# Judge Agent
JUDGE_ACCOUNT_ID=0.0.XXXXX
JUDGE_PRIVATE_KEY=302e...

# LLM Judge (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Judge tuning (optional — default 30000ms)
RESULTS_WAIT_MS=30000

# Requester tuning (optional — default 60000ms)
# How long to wait for bids before proceeding with available workers (or erroring if 0 bids)
# BID_TIMEOUT_MS=60000
